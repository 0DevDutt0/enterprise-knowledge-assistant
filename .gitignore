# =============================================================================
# Enterprise Knowledge Assistant — .gitignore
# =============================================================================

# =============================================================================
# SECRETS — never commit
# =============================================================================
.env
.env.local
.env.*.local
.streamlit/secrets.toml

# =============================================================================
# DATA — generated at runtime; never commit
# =============================================================================
data/raw/*
data/processed/*
data/vector_store/*

# Keep the directories so git tracks their existence
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/vector_store/.gitkeep

# FAISS index files (also covered above, but explicit for safety)
*.faiss
*.index
*.pkl

# Evaluation reports are generated — commit only if you want to pin a baseline
docs/eval-reports/*.md
!docs/eval-reports/.gitkeep

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / build
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Type stubs
*.pyi

# =============================================================================
# VIRTUAL ENVIRONMENTS
# =============================================================================
.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/
*.coveragerc

# =============================================================================
# LINTING & TYPE CHECKING
# =============================================================================
.mypy_cache/
.ruff_cache/
.pylintrc

# =============================================================================
# JUPYTER (if used for exploration)
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# IDE / EDITORS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# =============================================================================
# DOCKER (for local dev containers)
# =============================================================================
.dockerignore

# =============================================================================
# NODE (unlikely but guard against accidental installs)
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
