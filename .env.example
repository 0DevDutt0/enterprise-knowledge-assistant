# .env.example
# Copy to .env and fill in real values. Never commit .env.

# ----------------------------------------------------------------------
# LLM (Groq)
# ----------------------------------------------------------------------
GROQ_API_KEY=
# Set to the current best free model at the time of deployment.
# Check https://console.groq.com/docs/models for the live list.
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_RETRIES=2

# ----------------------------------------------------------------------
# Embeddings & reranking
# ----------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base

# cpu or cuda. The system runs end-to-end on cpu; cuda is a speedup.
DEVICE=cpu

# Embedder batch size. Lower if you OOM on CPU.
EMBEDDING_BATCH_SIZE=32

# ----------------------------------------------------------------------
# Chunking
# ----------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ----------------------------------------------------------------------
# Retrieval
# ----------------------------------------------------------------------
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5

# Rerank score below this -> system returns canonical "not found" answer
# instead of invoking the LLM. CrossEncoder logits: positive = relevant,
# ~0 = uncertain, < -3 = actively irrelevant. Keep negative to ensure the
# LLM is called for all plausible matches; the prompt handles true gaps.
CONFIDENCE_FLOOR=-3.0

# ----------------------------------------------------------------------
# Retrieval mode
# ----------------------------------------------------------------------
# "semantic" uses FAISS dense search only (default, lower latency).
# "hybrid"   fuses BM25 keyword search with FAISS via Reciprocal Rank Fusion.
# Hybrid improves recall on proper nouns, codes, IDs, and rare terms.
RETRIEVAL_MODE=semantic
# RRF constant k -- higher k reduces the impact of top-ranked results.
RRF_K=60

# ----------------------------------------------------------------------
# Query rewriting
# ----------------------------------------------------------------------
# Set to true to rewrite queries before retrieval using the LLM.
# Improves recall on vague / pronoun-heavy inputs. Adds ~1 Groq API call.
QUERY_REWRITING_ENABLED=false
QUERY_REWRITE_TEMPLATE_PATH=app/rag/prompts/query_rewrite_prompt.md

# ----------------------------------------------------------------------
# Generation
# ----------------------------------------------------------------------
# Path to the system prompt template (relative to repo root).
PROMPT_TEMPLATE_PATH=app/rag/prompts/system_prompt.md
# Max characters of retrieved context packed into the LLM prompt.
# 5 chunks x 800 chars = 4000; reduce if hitting Groq token limits.
MAX_CONTEXT_CHARS=4000
# Number of prior conversation turns injected into the prompt for context.
# Higher values improve follow-up accuracy but increase token usage.
MAX_HISTORY_TURNS=5

# ----------------------------------------------------------------------
# OCR
# ----------------------------------------------------------------------
# Set to false to disable OCR fallback entirely (scanned PDFs will yield
# zero chunks and a warning).
OCR_ENABLED=true
# Override only if tesseract is not on PATH.
TESSERACT_CMD=

# ----------------------------------------------------------------------
# Storage paths (relative to repo root)
# ----------------------------------------------------------------------
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
VECTOR_STORE_DIR=data/vector_store

# ----------------------------------------------------------------------
# API
# ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins for CORS. Use http://localhost:8501 for the
# Streamlit UI during local dev.
CORS_ORIGINS=http://localhost:8501

# ----------------------------------------------------------------------
# UI
# ----------------------------------------------------------------------
# Where the Streamlit UI reaches the API. Leave as default for local dev.
API_BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json
